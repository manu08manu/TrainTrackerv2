<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimaryContainer"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_share"
            android:contentDescription="@string/share_service"
            app:tint="@color/white"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- ── Service header card ──────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- ── Row A: Origin → Destination (large) ─────────────── -->
            <TextView
                android:id="@+id/tvServiceTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- ── Row B: Dep time subtitle ────────────────────────── -->
            <TextView
                android:id="@+id/tvServiceSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

            <!-- ── Divider ──────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.4"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <!-- ── Row C: TOC badge | Operator | Headcode | Platform ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
        android:baselineAligned="false"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgTocLogo"
                    android:layout_width="50dp"
                    android:contentDescription="@string/toc_logo_description"
                    android:layout_height="22dp"
                    android:scaleType="fitStart"
                    android:adjustViewBounds="true"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvTocBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_toc_badge"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvOperator"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Headcode pill -->
                <TextView
                    android:id="@+id/tvTrainId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_delay_reason"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>

                <!-- Platform pill -->
                <TextView
                    android:id="@+id/tvPlatform"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_delay_reason"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- ── Row D: Unit / RSID / coach count ─────────────────── -->
            <TextView
                android:id="@+id/tvRsid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

            <!-- Hidden (kept for compat) -->
            <TextView
                android:id="@+id/tvFormation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- ── Row E: Alert / cancel / delay reason ──────────────── -->
            <TextView
                android:id="@+id/tvReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/status_delayed"
                android:layout_marginTop="6dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Unit allocation + punctuality card ─────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUnitHsp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
        android:baselineAligned="false"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Unit allocation (left) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvUnitAllocationLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_unit_allocation"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:letterSpacing="0.08"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvUnitAllocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvUnitNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvSplitInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FF6D00"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Punctuality badge (right) -->
            <LinearLayout
                android:id="@+id/layoutPunctuality"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_toc_badge"
                android:layout_marginStart="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvPunctualityPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_on_time"
                    android:textSize="11sp"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tvPunctualitySample"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:alpha="0.8"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Cancelled banner -->
    <TextView
        android:id="@+id/tvCancelledBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/service_cancelled_banner"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/status_cancelled"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"/>

    <!-- Live TRUST location banner ("Know Your Train") -->
    <LinearLayout
        android:id="@+id/bannerLiveLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:background="?attr/colorPrimaryContainer"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvLiveLocationDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/live_indicator_dot"
            android:textColor="@color/status_ontime"
            android:textSize="11sp"/>
        <TextView
            android:id="@+id/tvLiveLocationText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"/>
        <TextView
            android:id="@+id/tvLiveLocationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/status_ontime"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textSize="14sp"
        android:textColor="@color/status_cancelled"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
        android:baselineAligned="false"
            android:paddingHorizontal="14dp"
            android:paddingTop="2dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_calling_points"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSimple"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_simple"
                android:checkable="true"
                android:checked="true"
                android:textSize="11sp"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDetailed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_detailed"
                android:checkable="true"
                android:textSize="11sp"
                android:layout_marginStart="6dp"
                style="@style/Widget.Material3.Chip.Filter"/>
        </LinearLayout>

        <!-- Passing station note — only shown in Detailed mode -->
        <TextView
            android:id="@+id/tvPassingNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/passing_stations_note"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textStyle="italic"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvNoCallingPoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_calling_points"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:padding="16dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCallingPoints"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="16dp"
            android:clipToPadding="false"/>
    </LinearLayout>
</LinearLayout>
