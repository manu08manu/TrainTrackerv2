<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- TOC/category-coloured left bar -->
        <View
            android:id="@+id/statusBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/status_ontime"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="10dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- ── Row 1: TIME | DESTINATION | STATUS ────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
        android:baselineAligned="false"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="?attr/colorOnSurface"
                    android:minWidth="62dp"/>

                <TextView
                    android:id="@+id/tvMainLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingHorizontal="10dp"/>

                <!-- Punctuality badge (% on time from HSP) -->
                <TextView
                    android:id="@+id/tvPunctuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:minWidth="60dp"/>

            </LinearLayout>

            <!-- ── Row 2: HEADCODE+TAG | sub-info | TOC+PLATFORM | COUNTDOWN ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
        android:baselineAligned="false"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <!-- Headcode + schedule tag -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
        android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:minWidth="62dp">

                    <TextView
                        android:id="@+id/tvHeadcode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvScheduleTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="1dp"
                        android:background="@drawable/bg_toc_badge"
                        android:layout_marginStart="4dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- Sub-label + approach state + service type icon -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
        android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp">

                    <TextView
                        android:id="@+id/tvSubLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvApproachState"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:textColor="@color/approach_state_text"
                        android:layout_marginStart="4dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvServiceType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- TOC logo / badge + Platform -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
        android:baselineAligned="false"
                    android:gravity="center_vertical">

                    <!-- NSI status dot: green=good (hidden), amber=minor, orange=major, red=severe -->
                    <ImageView
                        android:id="@+id/nsiDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="@string/nsi_dot_description"
                        android:visibility="gone"/>

                    <ImageView
                        android:id="@+id/imgTocLogo"
                        android:layout_width="72dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/toc_logo_description"
                        android:scaleType="fitStart"
                        android:adjustViewBounds="true"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvTocBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_toc_badge"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvPlatform"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                </LinearLayout>

                <!-- Delay pill + countdown + alert -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end|center_vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvDelay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:paddingHorizontal="5dp"
                        android:paddingVertical="1dp"
                        android:background="@drawable/bg_delay_pill"
                        android:gravity="end"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="1dp"
                        android:gravity="end"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvAlertIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/icon_info"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="1dp"
                        android:gravity="end"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Row 3: Journey time ───────────────────────────────────── -->
            <TextView
                android:id="@+id/tvJourneyTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>

            <!-- ── Row 4: Split/coupling info (unit board only) ─────────── -->
            <TextView
                android:id="@+id/tvSplitInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FF6D00"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone"/>

            <!-- ── Row 4b: Coupling info ──────────────────────────────────── -->
            <TextView
                android:id="@+id/tvCouplingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone"/>
            <!-- ── Row 5: Forms next service (unit board only) ─────────────── -->
            <TextView
                android:id="@+id/tvFormsNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FF1565C0"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>
            <!-- ── Row 6: Unit formation (unit board only) ──────────────── -->
            <TextView
                android:id="@+id/tvUnitFormation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>