<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <!-- ── Timeline column ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="20dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:id="@+id/lineTop"
            android:layout_width="2dp"
            android:layout_height="14dp"
            android:background="?attr/colorOutline"/>

        <ImageView
            android:id="@+id/dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_circle"
            android:contentDescription="@null"
            app:tint="?attr/colorPrimary"/>

        <View
            android:id="@+id/lineBottom"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="14dp"
            android:background="?attr/colorOutline"/>
    </LinearLayout>


    <!-- ── Station content ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Row 1: Station name + scheduled time (struck if late) + actual time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
        android:baselineAligned="false"
            android:gravity="center_vertical">

            <!-- Station name -->
            <TextView
                android:id="@+id/tvStation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- CRS code — visible only in Detailed -->
            <TextView
                android:id="@+id/tvCrs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <!-- Scheduled time — visible only in Detailed, struck-through if late -->
            <TextView
                android:id="@+id/tvScheduled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <!-- Actual/estimated time — always visible -->
            <TextView
                android:id="@+id/tvActual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <!-- Delay badge — inline after actual time -->
            <TextView
                android:id="@+id/tvDelayMin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="11sp"
                android:textColor="@color/status_delayed"
                android:textStyle="bold"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Row 2: Detailed extras — arr/dep label, delay, platform, coaches -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
        android:baselineAligned="false"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvArrDep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textStyle="italic"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvPlatform"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvLength"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvPassingTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_passing"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:background="@drawable/bg_delay_reason"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Row 3: Split branch indicator -->
        <LinearLayout
            android:id="@+id/layoutSplitBranch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
        android:baselineAligned="false"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_branch"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/tvSplitNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FF6D00"
                android:textStyle="bold"/>
        </LinearLayout>



    </LinearLayout>
</LinearLayout>